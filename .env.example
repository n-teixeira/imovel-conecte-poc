# =============================================================================
# ImovelConecte - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com credenciais reais
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados
# -----------------------------------------------------------------------------
# Para desenvolvimento local (H2 em memória):
DATABASE_URL=jdbc:h2:mem:imovelconecte;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DATABASE_USERNAME=sa
DATABASE_PASSWORD=
DATABASE_DRIVER=org.h2.Driver

# Para produção (PostgreSQL):
# DATABASE_URL=jdbc:postgresql://localhost:5432/imovelconecte
# DATABASE_USERNAME=imovelconecte
# DATABASE_PASSWORD=sua_senha_segura
# DATABASE_DRIVER=org.postgresql.Driver

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# -----------------------------------------------------------------------------
# HubSpot OAuth 2.0
# Obtenha as credenciais em: https://developers.hubspot.com/
# -----------------------------------------------------------------------------
HUBSPOT_CLIENT_ID=seu_client_id
HUBSPOT_CLIENT_SECRET=seu_client_secret
HUBSPOT_REDIRECT_URI=http://localhost:8080/oauth/callback

# Webhook - Token para validação e assinatura
HUBSPOT_WEBHOOK_VERIFICATION_TOKEN=token_verificacao_webhook
HUBSPOT_WEBHOOK_SECRET=secret_assinatura_webhook

# -----------------------------------------------------------------------------
# Idempotência e Contingência
# -----------------------------------------------------------------------------
# TTL em minutos para chaves de idempotência (padrão: 24h)
IDEMPOTENCY_TTL_MINUTES=1440

# Máximo de tentativas na fila de contingência
CONTINGENCY_MAX_RETRIES=5

# Intervalo entre retentativas em ms (padrão: 1 minuto)
CONTINGENCY_RETRY_DELAY_MS=60000

# -----------------------------------------------------------------------------
# Opcional - Debug
# -----------------------------------------------------------------------------
# JPA_SHOW_SQL=true
